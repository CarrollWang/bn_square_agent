# Optional public MCP entrypoint
#
# Use this only when the MCP server must be reachable through Nginx.
# If the web app and MCP server are on the same machine, the safer setup is:
#   MCP_URL=http://127.0.0.1:8788/mcp
# and do not expose MCP publicly at all.
#
# Do not put Basic Auth in front of /mcp unless your client is configured for it.
# This project already supports MCP bearer auth via MCP_SERVER_AUTH_TOKEN.

server {
    listen 80;
    listen [::]:80;
    server_name mcp.example.com;

    return 301 https://$host$request_uri;
}

upstream bn_square_agent_mcp {
    server 127.0.0.1:8788;
    keepalive 16;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name mcp.example.com;

    ssl_certificate /etc/letsencrypt/live/mcp.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/mcp.example.com/privkey.pem;

    client_max_body_size 20m;

    # Strongly recommended when exposing MCP publicly.
    # allow 203.0.113.10;
    # allow 198.51.100.0/24;
    # deny all;

    add_header X-Content-Type-Options nosniff always;

    location = / {
        return 404;
    }

    location /mcp {
        proxy_pass http://bn_square_agent_mcp/mcp;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300;
        proxy_send_timeout 300;
    }
}
