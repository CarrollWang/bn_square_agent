# BN Square Agent Web console
#
# Recommended topology:
# - FastAPI web app listens on 127.0.0.1:8787
# - Only Nginx exposes 443 to the public internet
# - Protect the console with Basic Auth and optionally an IP allowlist

server {
    listen 80;
    listen [::]:80;
    server_name agent.example.com;

    return 301 https://$host$request_uri;
}

upstream bn_square_agent_web {
    server 127.0.0.1:8787;
    keepalive 16;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name agent.example.com;

    ssl_certificate /etc/letsencrypt/live/agent.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/agent.example.com/privkey.pem;

    client_max_body_size 20m;

    # Optional: restrict by source IP before the password check.
    # allow 203.0.113.10;
    # allow 198.51.100.0/24;
    # deny all;

    auth_basic "BN Square Agent";
    auth_basic_user_file /etc/nginx/.htpasswd_bn_square_agent;

    add_header X-Frame-Options SAMEORIGIN always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy same-origin always;

    location / {
        proxy_pass http://bn_square_agent_web;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300;
        proxy_send_timeout 300;
    }
}
