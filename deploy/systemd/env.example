# Store the real file at /etc/bn-square-agent/env with mode 600.
# Never commit real credentials, cookies, API keys, or auth tokens.

DATABASE_PATH=/opt/bn-square-agent/data/bn_square.db
CHROMA_PATH=/opt/bn-square-agent/chroma_db
SECRET_KEY_PATH=/opt/bn-square-agent/data/app_secret.key

MCP_URL=http://127.0.0.1:8788/mcp
MCP_PUBLISH_TOOL=publish_binance_square
MCP_SERVER_AUTH_TOKEN=replace-with-a-long-random-token
MCP_AUTH_TOKEN=replace-with-the-same-token
MCP_SERVER_DEBUG_DIR=/opt/bn-square-agent/data/mcp_debug
MCP_SERVER_PUBLISH_WAIT_MS=12000

LLM_API_KEY=
LLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
LLM_MODEL=glm-5.2
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_MODEL=embedding-3

# Enable these only after one verified manual post.
AUTO_MONITOR_ENABLED=0
AUTO_CONSUME_MATERIALS=0
AUTO_PUBLISH=0