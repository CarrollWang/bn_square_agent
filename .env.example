LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# openai 兼容模式支持智谱等服务；API Key / Base URL 留空时复用上面的 LLM 配置。
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=embedding-3

APP_SECRET_KEY=
SECRET_KEY_PATH=./data/app_secret.key

# 保持为空时仅允许本机直接访问；如需从其他电脑直连管理台，请同时配置。
WEB_AUTH_USERNAME=
WEB_AUTH_PASSWORD=
# 仅用于明确接受风险的临时调试，不建议开启。
ALLOW_INSECURE_PUBLIC_BIND=0

# Web 只负责发起登录；登录浏览器实际由自建 MCP 服务持有。
COOKIE_LOGIN_BROWSER_ENABLED=
# 可选：作为登录浏览器的默认代理。
COOKIE_LOGIN_PROXY_URL=
BINANCE_PROFILE_ROOT=./data/browser_profiles

MCP_URL=
MCP_PUBLISH_TOOL=publish_binance_square
MCP_AUTH_TOKEN=
AUTO_PUBLISH=1

MCP_SERVER_AUTH_TOKEN=
MCP_SERVER_DEFAULT_PROXY=
MCP_SERVER_DEBUG_DIR=./data/mcp_debug
MCP_SERVER_PUBLISH_WAIT_MS=12000
# 必须使用可交互登录时保持为 0；服务器可配合 Xvfb/noVNC 提供图形会话。
MCP_BROWSER_HEADLESS=0

AUTO_CONSUME_MATERIALS=1
MATERIAL_CONSUME_BATCH_SIZE=1
MATERIAL_POLL_INTERVAL_SECONDS=300
MATERIAL_TTL_SECONDS=7200
